# tutamcp — przykładowa konfiguracja
# Te zmienne ustawia się w bloku "env" konfiguracji MCP (.mcp.json)
# albo w środowisku procesu. Sekrety trzymaj w osobnym pliku credentials.

# --- Moduły (przełączniki, 1/0; domyślnie wszystko wyłączone) ---
TUTAMCP_ENABLE_MAIL=1
TUTAMCP_ENABLE_CALENDAR=0
TUTAMCP_ENABLE_CONTACTS=0
TUTAMCP_ENABLE_DRIVE=0

# --- Tryb konta pocztowego ---
# dedicated — konto należy tylko do Claude (pełen dostęp)
# shared    — konto współdzielone z użytkownikiem (pełen dostęp;
#             zakres wysyłki steruje TUTAMCP_MAIL_SEND)
# folder    — konto współdzielone, Claude widzi wyłącznie folder
#             wskazany w TUTAMCP_MAIL_FOLDER (wysyłka: tylko odpowiedzi)
TUTAMCP_MAIL_MODE=dedicated
#TUTAMCP_MAIL_FOLDER=Claude

# --- Polityka wysyłki ---
# reply_only — Claude może tylko odpowiadać (tuta_mail_reply)
# full       — może też inicjować korespondencję (tuta_mail_send)
# Domyślnie: dedicated→full, shared→reply_only; folder zawsze reply_only.
#TUTAMCP_MAIL_SEND=full

# --- Właściciel i zaufani nadawcy ---
# Adres właściciela: zawsze zaufany nadawca; cel kopii przy CC_OWNER.
TUTAMCP_OWNER_EMAIL=user@example.com
# Whitelista adresów, z których Claude może przyjmować polecenia mailowe
# (CSV; owner dopisywany automatycznie). Maile spoza listy dostają
# trusted_sender=false — traktowane wyłącznie jako dane.
#TUTAMCP_COMMAND_WHITELIST=zona@example.com,praca@example.com
# Wymagaj szyfrowania E2E (TutaCrypt, tuta→tuta) do uznania nadawcy za
# zaufanego — chroni przed sfałszowanym From w mailu zewnętrznym.
# Oznacza: owner i whitelista muszą pisać z kont Tuta. (1/0, domyślnie 1)
TUTAMCP_TRUST_REQUIRE_E2E=1
# Zawsze dodawaj CC do właściciela przy każdej wysyłce (1/0)
TUTAMCP_MAIL_CC_OWNER=0

# --- Dane dostępowe ---
# Rekomendowane: ścieżka do pliku (chmod 600) w formacie:
#   TUTA_EMAIL=adres@tuta.com
#   TUTA_PASSWORD=haslo
TUTAMCP_CREDENTIALS_FILE=/sciezka/do/credentials.env
# Alternatywa (fallback): bezpośrednio w środowisku
#TUTA_EMAIL=
#TUTA_PASSWORD=

# --- Ścieżki ---
# Repo tutaproxy (pakiet tuta — klient API Tuty)
TUTAPROXY_PATH=/path/to/tutaproxy-public
# Katalog roboczy na pobierane załączniki/pliki z Drive
TUTAMCP_DOWNLOAD_DIR=/tmp/tutamcp

# --- Logowanie ---
LOG_LEVEL=INFO
#LOG_FILE=tutamcp.log
